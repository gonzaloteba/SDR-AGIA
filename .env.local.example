# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Typeform
TYPEFORM_WEBHOOK_SECRET=your-typeform-webhook-secret
TYPEFORM_API_TOKEN=your-typeform-api-token

# Default coach assigned to clients created via webhooks
DEFAULT_COACH_ID=your-coach-uuid

# Google App Script (transcript webhook)
GOOGLE_SCRIPT_SECRET=your-google-script-secret

# Cron Job
CRON_SECRET=your-cron-secret
