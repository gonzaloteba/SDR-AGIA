# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Typeform
TYPEFORM_WEBHOOK_SECRET=your-typeform-webhook-secret
TYPEFORM_API_TOKEN=your-typeform-api-token

# Default coach assigned to clients created via webhooks
DEFAULT_COACH_ID=your-coach-uuid

# Google App Script (transcript webhook)
GOOGLE_SCRIPT_SECRET=your-google-script-secret

# Calendly
CALENDLY_API_TOKEN=your-calendly-personal-access-token
# Optional: Calendly webhook signature verification key
# Get this from Calendly webhook subscription settings
CALENDLY_WEBHOOK_SIGNING_KEY=your-calendly-webhook-signing-key

# Cron Job
CRON_SECRET=your-cron-secret

# Optional: Set to "true" to allow /api/migrate/* endpoints in production
# ALLOW_MIGRATIONS=true
